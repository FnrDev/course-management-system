<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <title>Edit <%= instructor.firstName %> <%= instructor.lastName %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/navbar') %>
    <%- include('../partials/sidebar') %>

    <main class="form-page">
        <a class="back-link" href="/instructors/<%= instructor._id %>">← Back to instructor</a>
        <h1>Edit instructor</h1>

        <form class="form" action="/instructors/<%= instructor._id %>?_method=PUT" method="POST">
            <div class="field">
                <label for="staff-number">Staff number</label>
                <input
                    type="text"
                    name="staffNumber"
                    id="staff-number"
                    value="<%= instructor.staffNumber %>"
                    required
                >
            </div>

            <div class="field">
                <label for="first-name">First name</label>
                <input
                    type="text"
                    name="firstName"
                    id="first-name"
                    value="<%= instructor.firstName %>"
                    minlength="3"
                    maxlength="100"
                    required
                >
            </div>

            <div class="field">
                <label for="last-name">Last name</label>
                <input
                    type="text"
                    name="lastName"
                    id="last-name"
                    value="<%= instructor.lastName %>"
                    minlength="3"
                    maxlength="100"
                    required
                >
            </div>

            <div class="field">
                <label for="status">Status</label>
                <select name="status" id="status" required>
                    <option value="active" <%= instructor.status === 'active' ? 'selected' : '' %>>Active</option>
                    <option value="inactive" <%= instructor.status === 'inactive' ? 'selected' : '' %>>Inactive</option>
                    <option value="former" <%= instructor.status === 'former' ? 'selected' : '' %>>Former</option>
                </select>
            </div>

            <div class="form-actions">
                <button class="btn btn-solid" type="submit">Save changes</button>
                <a class="btn btn-ghost" href="/instructors/<%= instructor._id %>">Cancel</a>
            </div>
        </form>
    </main>
</body>
</html>
