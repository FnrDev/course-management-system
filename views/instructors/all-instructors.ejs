<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>instructors</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/navbar') %>
    <%- include('../partials/sidebar') %>

    <main>
        <header class="page-head">
            <h1>instructors</h1>
            <% if (user && user.role === 'admin') { %>
                <a class="btn btn-solid" href="/instructors/new">New instructor</a>
            <% } %>
        </header>

        <% if (instructors.length === 0) { %>
            <p class="empty">No instructors match your search.</p>
        <% } else { %>
            <ul class="card-grid">
                <% instructors.forEach(instructor => { %>
                    <li class="card">
                        <header class="card-head">
                            <span class="card-code"><%= instructor.staffNumber %></span>
                        </header>

                        <h2 class="card-title">
                            <a href="/instructors/<%= instructor._id %>"><%= instructor.firstName + " " + instructor.lastName %></a>
                        </h2>

                        <footer class="card-meta">
                            <a class="btn btn-solid btn-sm" href="/instructors/<%= instructor._id %>">Go to instructor</a>
                        </footer>
                    </li>
                <% }) %>
            </ul>
        <% } %>
    </main>
</body>
</html>
