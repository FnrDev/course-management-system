<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <title>Sign In</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <%- include('../partials/navbar') %>
    <%- include('../partials/sidebar') %>

    <main class="auth">
      <h1>Sign in</h1>
      <p class="auth-sub">Welcome back to CourseHub.</p>

      <form class="form" action="/auth/sign-in" method="POST">
        <div class="field">
          <label for="email">Email</label>
          <input type="text" name="email" id="email" autocomplete="email" required />
        </div>

        <div class="field">
          <label for="password">Password</label>
          <input type="password" name="password" id="password" autocomplete="current-password" required />
        </div>

        <div class="form-actions">
          <button class="btn btn-solid" type="submit">Sign in</button>
        </div>

        <p class="auth-alt">New here? <a href="/auth/sign-up">Create an account</a></p>
      </form>
    </main>
  </body>
</html>
