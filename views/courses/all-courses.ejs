<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Courses</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/navbar') %>

    <main>
        <div class="page-head">
            <h1>Courses</h1>
            <% if (user && user.role === 'admin') { %>
                <a class="btn btn-solid" href="/courses/new">New Course</a>
            <% } %>
        </div>

        <% if (courses.length === 0) { %>
            <p class="empty">No courses match your search.</p>
        <% } else { %>
            <ul class="card-grid">
                <% courses.forEach(course => { %>
                    <li class="card">
                        <div class="card-head">
                            <span class="card-code"><%= course.code %></span>
                            <span class="pill <%= enrolled >= course.capacity ? 'pill-full' : 'pill-open' %>">
                                <%= enrolled[course._id] %>/<%= course.capacity %>
                            </span>
                        </div>

                        <h2 class="card-title">
                            <a href="/courses/<%= course._id %>"><%= course.name %></a>
                        </h2>

                        <p class="card-desc"><%= course.description %></p>

                        <div class="card-meta">
                            <span><%= course.credits %> credits</span>
                            <span>
                                <% if (course.instructor) { %>
                                    <%= course.instructor.firstName %> <%= course.instructor.lastName %>
                                <% } else { %>
                                    Unassigned
                                <% } %>
                            </span>
                        </div>
                    </li>
                <% }) %>
            </ul>
        <% } %>
    </main>
</body>
</html>
