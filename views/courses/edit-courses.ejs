<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <title>Edit <%= course.code %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/navbar') %>
    <%- include('../partials/sidebar') %>

    <main>
        <a class="back-link" href="/courses/<%= course._id %>">← Back to course</a>
        <h1>Edit <%= course.code %></h1>

        <form class="form" action="/courses/<%= course._id %>?_method=PUT" method="POST">
            <div class="field">
                <label for="code">Course code</label>
                <input type="text" name="code" id="code" value="<%= course.code %>" required>
            </div>

            <div class="field">
                <label for="name">Name</label>
                <input type="text" name="name" id="name" value="<%= course.name %>" minlength="3" maxlength="100" required>
            </div>

            <div class="field">
                <label for="description">Description</label>
                <textarea name="description" id="description" rows="4" minlength="3" maxlength="100" required><%= course.description %></textarea>
            </div>

            <div class="field-row">
                <div class="field">
                    <label for="credits">Credits</label>
                    <input type="number" name="credits" id="credits" value="<%= course.credits %>" min="1" required>
                </div>

                <div class="field">
                    <label for="capacity">Capacity</label>
                    <input type="number" name="capacity" id="capacity" value="<%= course.capacity %>" min="1" required>
                </div>
            </div>

            <div class="field">
                <label for="instructor">Instructor</label>
                <select name="instructor" id="instructor">
                    <option value="">Unassigned</option>
                    <% instructors.forEach(instructor => { %>
                        <option
                            value="<%= instructor._id %>"
                            <%= course.instructor && course.instructor.equals(instructor._id) ? 'selected' : '' %>
                        >
                            <%= instructor.firstName %> <%= instructor.lastName %>
                        </option>
                    <% }) %>
                </select>
            </div>

            <fieldset class="field prerequisite-field">
                <legend>Prerequisite courses</legend>
                <p class="field-help">Students must complete every selected course before they can enroll.</p>

                <% if (prerequisiteCourses.length === 0) { %>
                    <p class="prerequisite-empty">No other active courses are available.</p>
                <% } else { %>
                    <div class="prerequisite-options">
                        <% prerequisiteCourses.forEach(prerequisiteCourse => { %>
                            <label class="field-check">
                                <input
                                    type="checkbox"
                                    name="prerequisites"
                                    value="<%= prerequisiteCourse._id %>"
                                    <%= selectedPrerequisiteIds.includes(String(prerequisiteCourse._id)) ? 'checked' : '' %>
                                >
                                <span><strong><%= prerequisiteCourse.code %></strong> — <%= prerequisiteCourse.name %></span>
                            </label>
                        <% }) %>
                    </div>
                <% } %>
            </fieldset>

            <label class="field-check">
                <input type="checkbox" name="isActive" <%= course.isActive ? 'checked' : '' %>>
                Active — visible in the catalog
            </label>

            <div class="form-actions">
                <button class="btn btn-solid" type="submit">Save changes</button>
                <a class="btn btn-ghost" href="/courses/<%= course._id %>">Cancel</a>
            </div>
        </form>
    </main>
</body>
</html>
