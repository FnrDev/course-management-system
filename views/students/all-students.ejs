<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <title>students</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('../partials/navbar') %>
    <%- include('../partials/sidebar') %>

    <main>
        <header class="page-head">
            <h1>students</h1>
            <% if (user && user.role === 'admin') { %>
                <a class="btn btn-solid" href="/students/new">New students</a>
            <% } %>
        </header>

        <% if (students.length === 0) { %>
            <p class="empty">No students match your search.</p>
        <% } else { %>
            <ul class="card-grid">
                <% students.forEach(student => { %>
                    <li class="card">
                        <header class="card-head">
                            <span class="card-code">Student ID: <%= student.studentNumber %></span>
                        </header>

                        <h2 class="card-title">
                            <a href="/students/<%= student._id %>"><%= student.firstName + " " + student.lastName %></a>
                        </h2>

                        <footer class="card-meta">
                            <a class="btn btn-solid btn-sm" href="/students/<%= student._id %>">Go to student</a>
                        </footer>
                    </li>
                <% }) %>
            </ul>
        <% } %>
    </main>
</body>
</html>
