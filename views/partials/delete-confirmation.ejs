<button
    class="btn btn-danger"
    type="button"
    onclick="document.getElementById('<%= confirmId %>').showModal()"
>
    <%= typeof triggerLabel !== 'undefined' ? triggerLabel : 'Delete' %>
</button>

<dialog class="confirmation-dialog" id="<%= confirmId %>" aria-labelledby="<%= confirmId %>-title">
    <article class="confirmation-dialog-content">
        <header>
            <h2 id="<%= confirmId %>-title"><%= title %></h2>
        </header>
        <p><%= message %></p>

        <footer class="confirmation-actions">
            <form method="dialog">
                <button class="btn btn-ghost" type="submit">Cancel</button>
            </form>

            <form action="<%= action %>" method="POST">
                <button class="btn btn-danger" type="submit">
                    <%= typeof confirmLabel !== 'undefined' ? confirmLabel : 'Delete' %>
                </button>
            </form>
        </footer>
    </article>
</dialog>
