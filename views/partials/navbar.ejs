<nav class="navbar">
    <a class="navbar-brand" href="/">Course<span>Hub</span></a>

    <input type="checkbox" id="navbar-toggle" class="navbar-toggle">
    <label for="navbar-toggle" class="navbar-burger">
        <span></span><span></span><span></span>
    </label>

    <div class="navbar-menu">
        <ul class="navbar-links">
            <li><a href="/courses">Courses</a></li>
            <li><a href="/instructors">Instructors</a></li>

            <% if (user && user.role === 'student') { %>
                <li><a href="/enrollments">My Enrollments</a></li>
            <% } %>

            <% if (user && user.role === 'admin') { %>
                <li><a href="/students">Students</a></li>
                <li><a href="/courses/new">New Course</a></li>
                <li><a href="/instructors/new">Add Instructor</a></li>
            <% } %>
        </ul>

        <div class="navbar-actions">
            <% if (user) { %>
                <span class="navbar-role navbar-role-<%= user.role %>"><%= user.role %></span>
                <a class="navbar-btn navbar-btn-ghost" href="/auth/sign-out">Logout</a>
            <% } else { %>
                <a class="navbar-btn navbar-btn-ghost" href="/auth/sign-in">Login</a>
                <a class="navbar-btn navbar-btn-solid" href="/auth/sign-up">Sign up</a>
            <% } %>
        </div>
    </div>
</nav>
